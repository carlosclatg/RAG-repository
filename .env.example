# Ollama server URL
OLLAMA_URL=http://localhost:11434

# Ollama model used for answer generation and RAG mode routing
LLM_MODEL=mistral:7b-instruct

# Ollama model used for embeddings
EMBEDDING_MODEL=nomic-embed-text

# Path to the document to index
DOCUMENT_PATH=./texto.txt

# Directory where LanceDB persists its files
DB_PATH=./data

# Cohere API key — re-ranking is skipped when not set
# COHERE_API_KEY=your-key-here

# Minimum relevance score (0-1) to keep a chunk after Cohere re-ranking
RERANK_THRESHOLD=0.8

# Number of candidates to retrieve from the vector DB per query
QUERY_LIMIT=20

# Number of neighbour chunks to include around each semantic search hit
TEXT_CHUNK_WIDE=2
